---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/icons/Icon.astro';

const title = 'Mentoria Claude Code + AIOX';
const description = 'Tenha uma equipe de agentes de IA trabalhando para você. Mentoria intensiva e prática com turmas de no máximo 12 pessoas em Florianópolis.';
const ogImage = '/images/mentoria-og.png';
---

<style is:global>
  /* AIOX Design System Tokens */
  :root {
    --bb-blue: oklch(0.669 0.1837 248.81);
    --bb-flare: oklch(0.631 0.2116 36.21);
    --bb-error: oklch(0.6368 0.2078 25.33);

    /* Surfaces */
    --bb-canvas: oklch(0.1149 0 0);
    --bb-dark: oklch(0.1149 0 0);
    --bb-surface: oklch(0.1693 0.0041 285.95);
    --bb-surface-alt: oklch(0.231 0.0099 124.97);
    --bb-surface-panel: oklch(0.1785 0.0041 285.98);
    --bb-surface-console: oklch(0.184 0.0081 118.61);
    --bb-surface-hover-strong: oklch(0.1971 0.006 285.84);

    /* Text */
    --bb-cream: oklch(0.9639 0.0158 106.69);
    --bb-cream-alt: oklch(0.9644 0.0172 103.15);
    --bb-warm-white: oklch(0.9952 0.0235 106.82);
    --bb-dim: rgba(245, 244, 231, 0.4);
    --bb-muted: oklch(0.7952 0 0);
    --bb-meta: oklch(0.6927 0 0);

    /* Borders */
    --bb-border: rgba(156, 156, 156, 0.15);
    --bb-border-soft: rgba(156, 156, 156, 0.10);
    --bb-border-strong: #3D3D3D;
    --bb-border-hover: rgba(156, 156, 156, 0.24);
    --bb-border-input: rgba(156, 156, 156, 0.2);

    /* Spacing */
    --space-1: 0.25rem;
    --space-2: 0.5rem;
    --space-3: 0.75rem;
    --space-4: 1rem;
    --space-5: 1.25rem;
    --space-6: 1.5rem;
    --space-7: 2rem;
    --space-8: 2.5rem;
    --space-9: 3rem;
    --space-10: 4rem;
    --space-11: 5rem;
    --space-12: 6rem;

    /* Typography */
    --font-bb-display: 'TASA Orbiter', system-ui, sans-serif;
    --font-bb-sans: 'Geist', system-ui, sans-serif;
    --font-bb-mono: 'Geist Mono', 'Roboto Mono', monospace;
  }
</style>

<BaseLayout title={title} description={description} ogImage={ogImage}>
  <!-- Hero Section - Enterprise Clean -->
  <section id="hero" class="relative w-full min-h-[65vh] overflow-hidden" style="background: var(--bb-dark);">
    <!-- Background Image -->
    <img
      src="/images/mentoria-hero.png"
      alt="Mentoria Claude Code + AIOX"
      class="w-full h-[65vh] object-cover"
      style="object-position: center 25%; transform: scaleX(-1);"
    />

    <!-- Dark Overlay Gradient + Orange Subtle Accent -->
    <div class="absolute inset-0 bg-gradient-to-b from-[var(--bb-dark)]/50 via-[var(--bb-dark)]/75 to-[var(--bb-dark)]"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-[#FF4400]/3 via-transparent to-transparent"></div>

    <!-- Content -->
    <div class="absolute inset-0 flex flex-col justify-end" style="padding: var(--space-6) var(--space-6) var(--space-10);">
      <div class="mx-auto max-w-6xl w-full">
        <!-- Badge with Orange Accent (Clean) -->
        <div class="inline-flex items-center gap-2 backdrop-blur-sm border"
             style="background: var(--bb-surface); border-color: #FF4400; padding: var(--space-2) var(--space-4); margin-bottom: var(--space-4);">
          <span class="relative inline-flex h-2 w-2 rounded-full" style="background: #FF4400;"></span>
          <span style="color: #FF4400; font-family: var(--font-bb-mono); font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.12em; font-weight: 600;">Turmas Limitadas</span>
        </div>

        <!-- Headline com tipografia Display (Clean) -->
        <h1 style="font-family: var(--font-bb-display); font-size: clamp(1.75rem, 5vw, 3.5rem); font-weight: 800; color: var(--bb-cream); max-width: 56rem; line-height: 1.1; letter-spacing: -0.02em; text-shadow: 0 2px 8px rgba(0, 0, 0, 0.6); margin-bottom: var(--space-5);">
          Tenha uma Equipe de Agentes de IA <span style="color: #FF4400;">Trabalhando Para Você</span>
        </h1>

        <p style="font-family: var(--font-bb-sans); font-size: clamp(0.95rem, 2vw, 1.15rem); color: var(--bb-cream-alt); max-width: 48rem; line-height: 1.6; text-shadow: 0 1px 4px rgba(0, 0, 0, 0.5); margin-bottom: var(--space-8); opacity: 0.92;">
          Aprenda a criar, configurar e orquestrar agentes autônomos que executam tarefas complexas para você — da escrita de código à criação de conteúdo. <strong style="color: var(--bb-warm-white);">Mentoria intensiva e prática.</strong>
        </p>

        <!-- CTAs com Design System (Orange) -->
        <div style="display: flex; flex-wrap: wrap; gap: var(--space-4); margin-bottom: var(--space-5);">
          <a
            href="#inscricao"
            class="btn-primary inline-flex items-center justify-center gap-2 transition-all"
            style="background: #FF4400; color: white; padding: var(--space-4) var(--space-7); font-family: var(--font-bb-mono); font-size: 0.875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; box-shadow: 0 4px 12px rgba(255, 68, 0, 0.3);"
          >
            <span>Fale com um Especialista</span>
            <Icon name="arrow-right" size="16" />
          </a>
          <a
            href="#como-funciona"
            class="inline-flex items-center justify-center gap-2 backdrop-blur-md transition-all"
            style="border: 1px solid #FF4400/50; background: var(--bb-surface-panel); color: var(--bb-cream); padding: var(--space-4) var(--space-7); font-family: var(--font-bb-mono); font-size: 0.875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em;"
          >
            Como Funciona
            <Icon name="chevron-down" size="16" />
          </a>
        </div>

        <!-- Microcopy com Geist Mono (Orange) -->
        <p style="font-family: var(--font-bb-mono); font-size: 0.75rem; color: var(--bb-meta); text-transform: uppercase; letter-spacing: 0.1em; text-shadow: 0 1px 4px rgba(0, 0, 0, 0.6); display: flex; align-items: center; gap: 0.5rem;">
          <Icon name="clock" size="16" class="text-[#FF4400]" /> Máx. 12 pessoas <span style="opacity: 0.5;">|</span> <Icon name="check" size="16" class="text-[#FF4400]" /> Garantia 7 dias
        </p>
      </div>
    </div>
  </section>

  <!-- Seção PROBLEMA -->
  <section id="problema" class="relative py-16 sm:py-24 overflow-hidden" style="background: #08080C;">
    <!-- Background com gradiente radial e padrão de pontos -->
    <div class="absolute inset-0">
      <!-- Gradiente radial do canto superior esquerdo -->
      <div
        class="absolute inset-0 opacity-30"
        style="background: radial-gradient(100% 100% at 0% 0%, #2e2e2e 0%, #000000 100%); mask: radial-gradient(125% 100% at 0% 0%, #000000 0%, rgba(0, 0, 0, 0.224) 88%, rgba(0, 0, 0, 0) 100%);"
      ></div>

      <!-- Gradiente com tons laranja sutis -->
      <div
        class="absolute inset-0 opacity-10"
        style="background: radial-gradient(125% 125% at 20% 10%, rgba(255, 68, 0, 0.15) 0%, transparent 60%);"
      ></div>

      <!-- Padrão de pontos sutil -->
      <div
        class="absolute inset-0 opacity-20"
        style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.15) 1px, transparent 0); background-size: 24px 24px;"
      ></div>
    </div>

    <div class="relative z-10 mx-auto max-w-4xl px-5 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white sm:text-4xl lg:text-5xl text-center leading-tight sm:leading-tight">
        Você sabe que IA é o futuro. Mas ainda não conseguiu <span class="text-[#FF4400]">aproveitar o potencial dela</span>.
      </h2>

      <div class="mt-8 sm:mt-12 text-base sm:text-lg text-white/70 leading-relaxed space-y-5 sm:space-y-6">
        <p>
          Você já usa ChatGPT, Claude, talvez até outros modelos. Mas no fundo, sabe que está subutilizando.
        </p>
        <p>
          Você vê pessoas falando sobre <strong>agentes autônomos</strong>, sobre times inteiros de IA trabalhando em paralelo, sobre produtividade 10x. E pensa: <em>"Como eles chegaram lá?"</em>
        </p>
        <p class="text-white/80 font-medium text-sm sm:text-base">A verdade é:</p>
        <ul class="space-y-3 sm:space-y-4 ml-0 sm:ml-4">
          <li class="flex items-start gap-2 sm:gap-3">
            <Icon name="close" class="flex-shrink-0 w-5 h-5 sm:w-6 sm:h-6 text-[#FF4400]" />
            <span class="text-sm sm:text-base"><strong>Tutoriais do YouTube não são suficientes</strong> — falta contexto, falta prática guiada, falta alguém para tirar suas dúvidas na hora</span>
          </li>
          <li class="flex items-start gap-2 sm:gap-3">
            <Icon name="close" class="flex-shrink-0 w-5 h-5 sm:w-6 sm:h-6 text-[#FF4400]" />
            <span class="text-sm sm:text-base"><strong>Você não tem tempo para virar expert sozinho</strong> — entre trabalho, projetos e vida pessoal, explorar ferramentas novas vira "quando sobrar tempo"</span>
          </li>
          <li class="flex items-start gap-2 sm:gap-3">
            <Icon name="close" class="flex-shrink-0 w-5 h-5 sm:w-6 sm:h-6 text-[#FF4400]" />
            <span class="text-sm sm:text-base"><strong>Cada erro custa caro</strong> — configurações erradas, permissões, integrações que não funcionam... você perde horas (ou dias) tentando descobrir o que deu errado</span>
          </li>
        </ul>
        <p class="text-white font-semibold text-base sm:text-xl mt-6 sm:mt-8">
          E o pior: <span class="text-[#FF4400]">enquanto você espera, seus concorrentes já estão usando.</span>
        </p>
      </div>
    </div>
  </section>

  <!-- Seção SOLUÇÃO + CLAUDIA -->
  <section id="solucao" class="py-16 sm:py-24 bg-[#0C0C12]">
    <div class="mx-auto max-w-5xl px-5 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white sm:text-4xl lg:text-5xl text-center leading-tight sm:leading-tight">
        Imagine ter uma equipe de especialistas <span class="text-[#FF4400]">trabalhando para você 24/7</span>
      </h2>

      <div class="mt-8 sm:mt-12 text-base sm:text-lg text-white/70 leading-relaxed space-y-5 sm:space-y-6">
        <p>E se você pudesse:</p>
        <ul class="space-y-3 sm:space-y-4 ml-0 sm:ml-4">
          <li class="flex items-start gap-2 sm:gap-3">
            <Icon name="check" class="flex-shrink-0 w-5 h-5 sm:w-6 sm:h-6 text-[#FF4400]" />
            <span class="text-sm sm:text-base"><strong>Delegar tarefas complexas para agentes</strong> que nunca dormem, nunca erram contexto e custam uma fração de um funcionário?</span>
          </li>
          <li class="flex items-start gap-2 sm:gap-3">
            <Icon name="check" class="flex-shrink-0 w-5 h-5 sm:w-6 sm:h-6 text-[#FF4400]" />
            <span class="text-sm sm:text-base"><strong>Ter um dev senior, um QA, um designer, um copywriter</strong> — tudo rodando na sua máquina, integrado aos seus projetos?</span>
          </li>
          <li class="flex items-start gap-2 sm:gap-3">
            <Icon name="check" class="flex-shrink-0 w-5 h-5 sm:w-6 sm:h-6 text-[#FF4400]" />
            <span class="text-sm sm:text-base"><strong>Escalar sua produção sem contratar</strong> — criar 10 posts de LinkedIn, 5 apresentações e revisar 20 PRs... em uma tarde?</span>
          </li>
        </ul>
        <p class="text-white font-semibold text-base sm:text-xl mt-6 sm:mt-8 text-center">
          <strong>Isso não é ficção científica. É o que você vai construir nesta mentoria.</strong>
        </p>
      </div>
    </div>
  </section>

  <!-- Seção COMO FUNCIONA - 8 Encontros -->
  <section id="como-funciona" class="py-16 sm:py-24 bg-[#0C0C12]">
    <div class="mx-auto max-w-7xl px-5 sm:px-6 lg:px-8">
      <!-- Section Header -->
      <div class="text-center mb-10 sm:mb-16">
        <div class="inline-flex items-center gap-2 border border-[#FF4400]/30 bg-[#FF4400]/10 px-3 sm:px-4 py-1.5 mb-4 sm:mb-6">
          <span class="text-[#FF4400] text-[0.55rem] sm:text-[0.65rem]" style="font-family: 'Geist Mono', monospace; text-transform: uppercase; letter-spacing: 0.12em; font-weight: 600;">A Jornada</span>
        </div>
        <h2 class="text-2xl font-bold text-white sm:text-4xl lg:text-5xl leading-tight sm:leading-tight">
          Do Zero ao Time Completo em <span class="text-[#FF4400]">8 Semanas</span>
        </h2>
        <div class="mx-auto mt-4 sm:mt-6 w-16 sm:w-24 accent-line"></div>
        <p class="mt-4 sm:mt-6 text-sm sm:text-lg text-white/60 max-w-2xl mx-auto leading-relaxed">
          Cada encontro constrói sobre o anterior. Você não vai só assistir — vai <strong class="text-white/80">fazer</strong>. E vai sair de cada sessão com algo funcionando.
        </p>
      </div>

      <!-- 8 Encontros Grid -->
      <div class="grid gap-4 sm:gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        <!-- Encontro Presencial -->
        <div class="glass-card p-5 sm:p-6">
          <div class="flex items-start justify-between mb-3 sm:mb-4">
            <div class="flex items-center justify-center w-12 h-12 sm:w-14 sm:h-14 rounded-lg border-2 border-[#FF4400] bg-[#FF4400]/10">
              <span class="text-[#FF4400] font-bold text-xl sm:text-2xl" style="font-family: var(--font-bb-mono);">01</span>
            </div>
            <div class="inline-flex items-center border border-[#FF4400]/30 bg-[#FF4400]/20 text-[#FF4400] px-2 py-0.5">
              <span style="font-family: 'Geist Mono', monospace; font-size: 0.5rem; sm:font-size: 0.55rem; text-transform: uppercase; letter-spacing: 0.10em; font-weight: 600;">Presencial</span>
            </div>
          </div>
          <h3 class="text-base sm:text-lg font-bold text-white mb-1.5 sm:mb-2 leading-tight">Encontro Presencial — Florianópolis</h3>
          <p class="text-xs sm:text-sm text-white/50 mb-3 leading-snug">Fundamentos, Mindset & Setup Completo (4h)</p>

          <div class="space-y-1.5 sm:space-y-2 mb-3 sm:mb-4">
            <div class="text-[0.65rem] sm:text-xs text-white/40 leading-snug">
              <span class="text-[#FF4400] font-semibold">Parte 1 (1h):</span> Fundamentos conceituais
            </div>
            <div class="text-[0.65rem] sm:text-xs text-white/40 leading-snug">
              <span class="text-[#FF4400] font-semibold">Parte 2 (1h):</span> Desbloqueio Mental — Claudia
            </div>
            <div class="text-[0.65rem] sm:text-xs text-white/40 leading-snug">
              <span class="text-[#FF4400] font-semibold">Parte 3 (2h):</span> Workshop — Setup completo
            </div>
          </div>

          <div class="pt-2.5 sm:pt-3 border-t border-white/[0.08]">
            <p class="text-[0.6rem] sm:text-xs text-white/35 mb-1.5 sm:mb-2" style="font-family: 'Geist Mono', monospace;">Você sai com:</p>
            <ul class="space-y-1">
              <li class="text-[0.65rem] sm:text-xs text-white/50 flex items-start gap-1.5 sm:gap-2 leading-snug">
                <Icon name="check" size="16" class="text-[#FF4400] mt-0.5 flex-shrink-0" />
                <span>Computador 100% configurado</span>
              </li>
              <li class="text-[0.65rem] sm:text-xs text-white/50 flex items-start gap-1.5 sm:gap-2 leading-snug">
                <Icon name="check" size="16" class="text-[#FF4400] mt-0.5 flex-shrink-0" />
                <span>Mindset desbloqueado</span>
              </li>
              <li class="text-[0.65rem] sm:text-xs text-white/50 flex items-start gap-1.5 sm:gap-2 leading-snug">
                <Icon name="check" size="16" class="text-[#FF4400] mt-0.5 flex-shrink-0" />
                <span>Confiança para os próximos módulos</span>
              </li>
            </ul>
          </div>
        </div>

        <!-- Online 1 -->
        <div class="glass-card p-5 sm:p-6">
          <div class="flex items-start justify-between mb-3 sm:mb-4">
            <div class="flex items-center justify-center w-12 h-12 sm:w-14 sm:h-14 rounded-lg border-2 border-[#0EA5E9] bg-[#0EA5E9]/10">
              <span class="text-[#0EA5E9] font-bold text-xl sm:text-2xl" style="font-family: var(--font-bb-mono);">02</span>
            </div>
            <div class="inline-flex items-center border border-[#0EA5E9]/30 bg-[#0EA5E9]/20 text-[#0EA5E9] px-2 py-0.5">
              <span style="font-family: 'Geist Mono', monospace; font-size: 0.5rem; text-transform: uppercase; letter-spacing: 0.10em; font-weight: 600;">Online</span>
            </div>
          </div>
          <h3 class="text-base sm:text-lg font-bold text-white mb-1.5 sm:mb-2 leading-tight">Online 1 — Dominando o Claude Code</h3>
          <p class="text-xs sm:text-sm text-white/50 mb-3 leading-snug">Como Extrair o Máximo dos Agentes (2h)</p>

          <div class="space-y-1.5 sm:space-y-2 mb-3 sm:mb-4">
            <div class="text-[0.65rem] sm:text-xs text-white/40 leading-snug">
              Funcionalidades avançadas que 99% não usa
            </div>
            <div class="text-[0.65rem] sm:text-xs text-white/40 leading-snug">
              Sistema de permissões e segurança
            </div>
            <div class="text-[0.65rem] sm:text-xs text-white/40 leading-snug">
              Engenharia de prompts 10x melhor
            </div>
          </div>

          <div class="pt-2.5 sm:pt-3 border-t border-white/[0.08]">
            <p class="text-[0.6rem] sm:text-xs text-white/35 leading-snug" style="font-family: 'Geist Mono', monospace;">
              Formato: 1h conteúdo + 1h auxílio
            </p>
          </div>
        </div>

        <!-- Online 2 -->
        <div class="glass-card p-6">
          <div class="flex items-start justify-between mb-4">
            <div class="flex items-center justify-center w-12 h-12 sm:w-14 sm:h-14 rounded-lg border-2 border-[#0EA5E9] bg-[#0EA5E9]/10">
              <span class="text-[#0EA5E9] font-bold text-xl sm:text-2xl" style="font-family: var(--font-bb-mono);">03</span>
            </div>
            <div class="inline-flex items-center border border-[#0EA5E9]/30 bg-[#0EA5E9]/20 text-[#0EA5E9] px-2 py-0.5">
              <span style="font-family: 'Geist Mono', monospace; font-size: 0.55rem; text-transform: uppercase; letter-spacing: 0.10em; font-weight: 600;">Online</span>
            </div>
          </div>
          <h3 class="text-lg font-bold text-white mb-2">Online 2 — Skills</h3>
          <p class="text-sm text-white/50 mb-3">Expanda os Poderes dos Seus Agentes (2h)</p>

          <div class="space-y-2 mb-4">
            <div class="text-xs text-white/40 flex items-start gap-2">
              <span class="text-[#FF4400]">•</span>
              <span><code class="text-[#FF4400]">/pdf</code> — Ler, criar, editar PDFs</span>
            </div>
            <div class="text-xs text-white/40 flex items-start gap-2">
              <span class="text-[#FF4400]">•</span>
              <span><code class="text-[#FF4400]">/pptx</code> — Gerar apresentações completas</span>
            </div>
            <div class="text-xs text-white/40 flex items-start gap-2">
              <span class="text-[#FF4400]">•</span>
              <span><code class="text-[#FF4400]">/graphic-designer</code> — Design visual automatizado</span>
            </div>
            <div class="text-xs text-white/40 flex items-start gap-2">
              <span class="text-[#FF4400]">•</span>
              <span><code class="text-[#FF4400]">/copywriting</code> — Copy persuasivo em segundos</span>
            </div>
          </div>

          <div class="pt-3 border-t border-white/[0.08]">
            <p class="text-xs text-white/50">
              <Icon name="check" size="16" class="text-[#FF4400]" /> Skills essenciais instaladas e funcionando para seu contexto
            </p>
          </div>
        </div>

        <!-- Online 3 -->
        <div class="glass-card p-6">
          <div class="flex items-start justify-between mb-4">
            <div class="flex items-center justify-center w-12 h-12 sm:w-14 sm:h-14 rounded-lg border-2 border-[#0EA5E9] bg-[#0EA5E9]/10">
              <span class="text-[#0EA5E9] font-bold text-xl sm:text-2xl" style="font-family: var(--font-bb-mono);">04</span>
            </div>
            <div class="inline-flex items-center border border-[#0EA5E9]/30 bg-[#0EA5E9]/20 text-[#0EA5E9] px-2 py-0.5">
              <span style="font-family: 'Geist Mono', monospace; font-size: 0.55rem; text-transform: uppercase; letter-spacing: 0.10em; font-weight: 600;">Online</span>
            </div>
          </div>
          <h3 class="text-lg font-bold text-white mb-2">Online 3 — MCP Servers</h3>
          <p class="text-sm text-white/50 mb-3">Integre Seus Agentes com o Mundo (2h)</p>

          <div class="space-y-2 mb-4">
            <div class="text-xs text-white/40">
              <span class="text-[#8B5CF6] font-semibold">Playwright:</span> Automação de browsers
            </div>
            <div class="text-xs text-white/40">
              <span class="text-[#8B5CF6] font-semibold">Context7:</span> Documentação instantânea de qualquer biblioteca
            </div>
            <div class="text-xs text-white/40">
              <span class="text-[#8B5CF6] font-semibold">Apify:</span> Web scraping e extração de dados
            </div>
          </div>

          <div class="pt-3 border-t border-white/[0.08]">
            <p class="text-xs text-white/50">
              <Icon name="check" size="16" class="text-[#FF4400]" /> Integrações poderosas rodando no seu ambiente
            </p>
          </div>
        </div>

        <!-- Online 4 -->
        <div class="glass-card p-6">
          <div class="flex items-start justify-between mb-4">
            <div class="flex items-center justify-center w-12 h-12 sm:w-14 sm:h-14 rounded-lg border-2 border-[#0EA5E9] bg-[#0EA5E9]/10">
              <span class="text-[#0EA5E9] font-bold text-xl sm:text-2xl" style="font-family: var(--font-bb-mono);">05</span>
            </div>
            <div class="inline-flex items-center border border-[#0EA5E9]/30 bg-[#0EA5E9]/20 text-[#0EA5E9] px-2 py-0.5">

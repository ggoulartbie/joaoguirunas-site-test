    .check-icon {
      color: #22C55E;
      font-weight: 700;
      font-size: 1.2rem;
    }

    .guarantee-box {
      background: rgba(34, 197, 94, 0.1);
      border: 2px solid rgba(34, 197, 94, 0.3);
      border-radius: 8px;
      padding: 1.5rem;
      text-align: center;
    }

    .guarantee-icon {
      font-size: 2.5rem;
      margin-bottom: 0.5rem;
    }

    .guarantee-box h4 {
      font-size: 1.2rem;
      margin: 0.5rem 0;
      color: white;
    }

    .guarantee-box p {
      font-size: 0.95rem;
      color: rgba(255, 255, 255, 0.8);
      margin: 0;
    }

    /* FAQ Grid */
    .faq-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }

    .faq-item {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 8px;
      padding: 1.5rem;
    }

    .faq-item h4 {
      font-size: 1rem;
      margin: 0 0 0.8rem 0;
      color: white;
    }

    .faq-item p {
      font-size: 0.9rem;
      color: rgba(255, 255, 255, 0.7);
      line-height: 1.4;
      margin: 0;
    }

    /* CTA Slide */
    .slide-cta {
      display: flex !important;
      align-items: center;
      justify-content: center;
      text-align: center;
    }

    .cta-content {
      max-width: 900px;
    }

    .cta-title {
      font-size: 4.5rem;
      font-weight: 800;
      color: white;
      margin: 1rem 0;
      line-height: 1.1;
    }

    .cta-subtitle {
      font-size: 2rem;
      color: rgba(255, 255, 255, 0.9);
      margin-bottom: 2rem;
    }

    .cta-benefits {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
      margin: 2rem 0;
    }

    .benefit-item {
      font-size: 1.2rem;
      color: white;
      font-weight: 500;
    }

    .cta-footer {
      margin-top: 3rem;
    }

    .cta-text {
      font-size: 1.3rem;
      color: white;
      margin-bottom: 1rem;
    }

    .cta-note {
      font-size: 1rem;
      color: rgba(255, 255, 255, 0.8);
    }

    /* Deliverable Badge */
    .deliverable {
      background: rgba(14, 165, 233, 0.1);
      border: 1px solid rgba(14, 165, 233, 0.3);
      padding: 0.8rem 1.5rem;
      border-radius: 6px;
      margin-top: 1.5rem;
      text-align: center;
      font-size: 0.95rem;
      color: rgba(255, 255, 255, 0.9);
    }

    .deliverable.green {
      background: rgba(34, 197, 94, 0.1);
      border-color: rgba(34, 197, 94, 0.3);
    }

    .divider {
      width: 100%;
      height: 1px;
      background: rgba(255, 255, 255, 0.1);
      margin: 1.5rem 0;
    }

    /* Mobile Responsive */
    @media (max-width: 768px) {
      .reveal section {
        padding: 2rem 1.5rem;
      }

      .title-xl {
        font-size: 2.5rem;
      }

      .slide-title {
        font-size: 1.8rem;
      }

      .stats-grid,
      .timeline-grid,
      .content-grid-2,
      .skills-grid,
      .mcp-grid,
      .anatomy-grid,
      .final-grid,
      .personas-grid,
      .deliverables-grid,
      .included-grid,
      .faq-grid,
      .cta-benefits {
        grid-template-columns: 1fr;
        gap: 1rem;
      }

      .price-main {
        font-size: 2.5rem;
      }

      .cta-title {
        font-size: 2.5rem;
      }
    }

    /* Reveal.js Controls */
    .reveal .controls {
      color: #FF4400;
    }

    .reveal .progress {
      background: rgba(255, 255, 255, 0.1);
      color: #FF4400;
    }
  </style>

  <script is:inline>
    // Initialize Reveal.js
    Reveal.initialize({
      hash: true,
      controls: true,
      progress: true,
      center: false,
      slideNumber: 'c/t',
      transition: 'slide',
      backgroundTransition: 'fade',
      width: 1280,
      height: 720,
      margin: 0.04,
      minScale: 0.2,
      maxScale: 2.0,
      keyboard: {
        37: 'prev', // left arrow
        39: 'next', // right arrow
        38: 'prev', // up arrow
        40: 'next', // down arrow
      },
    });
  </script>
</BaseLayout>

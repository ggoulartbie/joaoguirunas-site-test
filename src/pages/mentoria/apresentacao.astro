---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Apresentação: Mentoria Claude Code + AIOX"
  description="Programa completo da Mentoria Claude Code + AIOX - Tenha uma equipe de agentes de IA trabalhando para você"
>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@5.0.4/dist/reveal.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@5.0.4/dist/theme/black.css">

  <div class="reveal">
    <div class="slides">

      <!-- SLIDE 1: COVER -->
      <section class="slide-cover" data-background-gradient="linear-gradient(135deg, #08080C 0%, #0C0C12 100%)">
        <div class="slide-content">
          <div class="badge-animated">
            <span class="ping"></span>
            <span class="label">TURMAS LIMITADAS</span>
          </div>
          <h1 class="title-xl">Mentoria<br/><span class="text-accent">Claude Code + AIOX</span></h1>
          <p class="subtitle">Tenha uma equipe de agentes de IA trabalhando para você</p>
          <div class="stats-grid">
            <div class="stat-item">
              <div class="stat-number">8</div>
              <div class="stat-label">Encontros</div>
            </div>
            <div class="stat-item">
              <div class="stat-number">~19h</div>
              <div class="stat-label">Totais</div>
            </div>
            <div class="stat-item">
              <div class="stat-number">12</div>
              <div class="stat-label">Max Alunos</div>
            </div>
          </div>
        </div>
      </section>

      <!-- SLIDE 2: VISÃO GERAL -->
      <section data-background-color="#0C0C12">
        <h2 class="slide-title">Visão Geral</h2>
        <div class="content-box">
          <p class="text-lg">Programa intensivo e prático que capacita profissionais e empresários a <strong class="text-accent">dominar agentes autônomos de IA</strong>.</p>

          <div class="divider"></div>

          <h3 class="subtitle-sm">Ao final do programa, você terá:</h3>
          <ul class="checklist">
            <li><span class="check">✓</span> Ambiente configurado com agentes funcionando</li>
            <li><span class="check">✓</span> Squad personalizada para suas necessidades</li>
            <li><span class="check">✓</span> Domínio técnico do Claude Code e AIOX</li>
            <li><span class="check">✓</span> Autonomia completa para criar agentes</li>
          </ul>
        </div>
      </section>

      <!-- SLIDE 3: ENCONTRO PRESENCIAL -->
      <section data-background-color="#08080C">
        <div class="badge-small">Presencial · 4h</div>
        <h2 class="slide-title">Encontro Presencial</h2>
        <h3 class="subtitle-sm">Fundamentos, Mindset & Setup</h3>

        <div class="timeline-grid">
          <div class="timeline-item">
            <div class="timeline-badge">1h</div>
            <h4>Fundamentos Conceituais</h4>
            <ul class="list-compact">
              <li>O que é Claude Code e AIOX</li>
              <li>Terminal para não-técnicos</li>
              <li>Visão: de chatbot a equipe autônoma</li>
            </ul>
          </div>

          <div class="timeline-item highlight">
            <div class="timeline-badge accent">1h</div>
            <h4>Desbloqueio Mental — Claudia Guirunas</h4>
            <p class="text-sm">Psicanalista e Sócia da GrowthSales</p>
            <ul class="list-compact">
              <li>Técnicas de respiração e desbloqueio</li>
              <li>Superar a resistência da tela preta</li>
              <li>Mindset para delegar a agentes</li>
            </ul>
          </div>

          <div class="timeline-item">
            <div class="timeline-badge">2h</div>
            <h4>Workshop Prático</h4>
            <ul class="list-compact">
              <li>Configuração completa dos computadores</li>
              <li>Instalação do Claude Code</li>
              <li>Setup de ferramentas essenciais</li>
            </ul>
          </div>
        </div>

        <div class="deliverable">
          <strong>Entregável:</strong> Computador 100% configurado + Mindset desbloqueado
        </div>
      </section>

      <!-- SLIDE 4: ONLINE 1 -->
      <section data-background-color="#0C0C12">
        <div class="badge-small blue">Online · 2h</div>
        <h2 class="slide-title">Online 1: Dominando o Claude Code</h2>

        <div class="content-grid-2">
          <div class="content-box-sm">
            <h4>Funcionalidades Avançadas</h4>
            <ul class="list-compact">
              <li>Navegação em projetos complexos</li>
              <li>Leitura e edição de arquivos</li>
              <li>Execução de comandos bash</li>
              <li>Integração Git/GitHub</li>
              <li>Gestão de contexto e memória</li>
            </ul>
          </div>

          <div class="content-box-sm">
            <h4>Sistema de Permissões</h4>
            <ul class="list-compact">
              <li>Modelo de segurança</li>
              <li>Configuração por projeto</li>
              <li>Boas práticas</li>
            </ul>

            <h4 style="margin-top: 1.5rem;">Engenharia de Prompts</h4>
            <ul class="list-compact">
              <li>Estrutura de prompts eficientes</li>
              <li>Técnicas de direcionamento</li>
              <li>Melhores resultados</li>
            </ul>
          </div>
        </div>

        <div class="deliverable">
          <strong>Entregável:</strong> Domínio completo do Claude Code
        </div>
      </section>

      <!-- SLIDE 5: ONLINE 2 -->
      <section data-background-color="#08080C">
        <div class="badge-small blue">Online · 2h</div>
        <h2 class="slide-title">Online 2: Skills</h2>

        <div class="content-box">
          <p class="text-lg">Compreenda o sistema de skills, aprenda a descobrir, instalar e usar skills essenciais.</p>

          <div class="skills-grid">
            <div class="skill-card">/pdf</div>
            <div class="skill-card">/pptx</div>
            <div class="skill-card">/docx</div>
            <div class="skill-card">/graphic-designer</div>
            <div class="skill-card">/copywriting</div>
            <div class="skill-card">/social-media-content</div>
          </div>

          <div class="info-box">
            <p><strong>1h de conteúdo</strong> + 1h de bate-papo e auxílio</p>
          </div>
        </div>

        <div class="deliverable">
          <strong>Entregável:</strong> Skills instaladas e funcionando
        </div>
      </section>

      <!-- SLIDE 6: ONLINE 3 -->
      <section data-background-color="#0C0C12">
        <div class="badge-small blue">Online · 2h</div>
        <h2 class="slide-title">Online 3: MCP Servers</h2>

        <div class="content-box">
          <h3 class="subtitle-sm">O que são MCP Servers?</h3>
          <p class="text-md">Model Context Protocol - Integração com ferramentas externas e APIs</p>

          <div class="mcp-grid">
            <div class="mcp-card">
              <div class="mcp-icon">🎭</div>
              <h4>Playwright</h4>
              <p>Automação de browser e screenshots</p>
            </div>
            <div class="mcp-card">
              <div class="mcp-icon">📚</div>
              <h4>Context7</h4>
              <p>Documentação de bibliotecas</p>
            </div>
            <div class="mcp-card">
              <div class="mcp-icon">🕷️</div>
              <h4>Apify</h4>
              <p>Web scraping e extração de dados</p>
            </div>
          </div>
        </div>

        <div class="deliverable">
          <strong>Entregável:</strong> MCPs instalados e integrados
        </div>
      </section>

      <!-- SLIDE 7: ONLINE 4 -->
      <section data-background-color="#08080C">
        <div class="badge-small blue">Online · 2h</div>
        <h2 class="slide-title">Online 4: Framework AIOX</h2>

        <div class="content-grid-2">
          <div class="content-box-sm">
            <h4>Arquitetura AIOX</h4>
            <ul class="list-compact">
              <li>Estrutura e conceitos fundamentais</li>
              <li>Constitution e princípios</li>
              <li>Sistema de camadas (L1-L4)</li>
            </ul>
          </div>

          <div class="content-box-sm">
            <h4>Sistema de Agentes</h4>
            <div class="agents-grid">
              <span class="agent-tag">@dev</span>
              <span class="agent-tag">@qa</span>
              <span class="agent-tag">@pm</span>
              <span class="agent-tag">@po</span>
              <span class="agent-tag">@sm</span>
              <span class="agent-tag">@architect</span>
              <span class="agent-tag">@devops</span>
            </div>
          </div>
        </div>

        <div class="content-box highlight-box">
          <h4>Workflows Principais:</h4>
          <div class="workflows">
            <span class="workflow-badge">Story Development Cycle (SDC)</span>
            <span class="workflow-badge">QA Loop</span>
            <span class="workflow-badge">Spec Pipeline</span>
          </div>
        </div>

        <div class="deliverable">
          <strong>Entregável:</strong> Compreensão completa do framework AIOX
        </div>
      </section>

      <!-- SLIDE 8: ONLINE 5 -->
      <section data-background-color="#0C0C12">
        <div class="badge-small blue">Online · 2h</div>
        <h2 class="slide-title">Online 5: Squads Personalizadas</h2>

        <div class="content-box">
          <p class="text-lg">Crie agentes customizados para suas necessidades específicas</p>

          <div class="anatomy-grid">
            <div class="anatomy-item">
              <div class="anatomy-number">1</div>
              <h4>Anatomia de um Agente</h4>
              <p>Estrutura de arquivos (YAML/Markdown)<br/>Persona, greeting, commands</p>
            </div>
            <div class="anatomy-item">
              <div class="anatomy-number">2</div>
              <h4>Criação de Agentes</h4>
              <p>Definição de escopo<br/>Escrita de prompts de sistema</p>
            </div>
            <div class="anatomy-item">
              <div class="anatomy-number">3</div>
              <h4>Workshop Prático</h4>
              <p>Criar agente para seu contexto<br/>Montar squad personalizada</p>
            </div>
          </div>
        </div>

        <div class="deliverable">
          <strong>Entregável:</strong> Primeira versão da squad personalizada
        </div>
      </section>

      <!-- SLIDE 9: ONLINE 6 -->
      <section data-background-color="#08080C">
        <div class="badge-small blue">Online · 2h</div>
        <h2 class="slide-title">Online 6: Integrações & Automações</h2>

        <div class="content-grid-2">
          <div class="content-box-sm">
            <h4>🔌 Integrações</h4>
            <ul class="list-compact">
              <li>APIs externas</li>
              <li>Webhooks e triggers</li>
              <li>Bancos de dados</li>
              <li>Serviços cloud</li>
            </ul>
          </div>

          <div class="content-box-sm">
            <h4>⚡ Automações Avançadas</h4>
            <ul class="list-compact">
              <li>Workflows complexos multi-agente</li>
              <li>Scheduling de tarefas</li>
              <li>Casos de uso avançados</li>
            </ul>
          </div>
        </div>

        <div class="info-box accent-box">
          <p><strong>Preparação do projeto final</strong> com orientações individuais</p>
        </div>

        <div class="deliverable">
          <strong>Entregável:</strong> Integrações funcionando e projeto final
        </div>
      </section>

      <!-- SLIDE 10: ENCONTRO FINAL -->
      <section data-background-color="#0C0C12">
        <div class="badge-small">Presencial ou Online · 2-3h</div>
        <h2 class="slide-title">Encontro Final</h2>
        <h3 class="subtitle-sm">Apresentações & Encerramento</h3>

        <div class="final-grid">
          <div class="final-card">
            <div class="final-icon">🎤</div>
            <h4>Apresentações</h4>
            <p>Cada participante apresenta sua squad personalizada e resultados alcançados</p>
          </div>

          <div class="final-card">
            <div class="final-icon">💬</div>
            <h4>Feedback</h4>
            <p>Feedback coletivo, reconhecimento das conquistas, melhores práticas</p>
          </div>

          <div class="final-card">
            <div class="final-icon">🎓</div>
            <h4>Certificação</h4>
            <p>Certificado de conclusão e acesso vitalício à comunidade</p>
          </div>
        </div>

        <div class="deliverable green">
          <strong>Entregável:</strong> Certificado + Comunidade vitalícia
        </div>
      </section>

      <!-- SLIDE 11: PERFIL DO ALUNO -->
      <section data-background-color="#08080C">
        <h2 class="slide-title">Para Quem É?</h2>

        <div class="alert-box">
          <p><strong>Esta mentoria NÃO é exclusiva para desenvolvedores.</strong> É para qualquer pessoa que queira aumentar eficiência com agentes autônomos.</p>
        </div>

        <div class="personas-grid">
          <div class="persona-card">
            <div class="persona-icon">💼</div>
            <h4>Empresários & Gestores</h4>
          </div>
          <div class="persona-card">
            <div class="persona-icon">🚀</div>
            <h4>Empreendedores</h4>
          </div>
          <div class="persona-card">
            <div class="persona-icon">📢</div>
            <h4>Marketing & Design</h4>
          </div>
          <div class="persona-card">
            <div class="persona-icon">📝</div>
            <h4>Consultores</h4>
          </div>
          <div class="persona-card">
            <div class="persona-icon">👨‍💻</div>
            <h4>Devs & Engenheiros</h4>
          </div>
          <div class="persona-card">
            <div class="persona-icon">📊</div>
            <h4>PMs & Tech Leads</h4>
          </div>
        </div>

        <div class="requirements-box">
          <h4>Requisitos:</h4>
          <ul class="list-inline">
            <li>Mac/Windows/Linux (8GB RAM+)</li>
            <li>Claude Pro (US$ 20/mês)</li>
            <li>Inglês técnico básico</li>
          </ul>
          <p class="note"><strong>Importante:</strong> Não é necessário conhecimento prévio de terminal. Ensinamos tudo do zero!</p>
        </div>
      </section>

      <!-- SLIDE 12: ENTREGÁVEIS -->
      <section data-background-color="#0C0C12">
        <h2 class="slide-title">O Que Você Terá ao Final</h2>

        <div class="deliverables-grid">
          <div class="deliverable-column">
            <div class="column-icon">⚙️</div>
            <h4>Técnico</h4>
            <ul class="checklist-sm">
              <li><span class="check green">✓</span> Ambiente 100% configurado</li>
              <li><span class="check green">✓</span> Claude Code dominado</li>
              <li><span class="check green">✓</span> Framework AIOX instalado</li>
              <li><span class="check green">✓</span> Squad personalizada</li>
              <li><span class="check green">✓</span> Skills e MCPs funcionando</li>
              <li><span class="check green">✓</span> Integrações com suas ferramentas</li>
            </ul>
          </div>

          <div class="deliverable-column">
            <div class="column-icon">🧠</div>
            <h4>Conhecimento</h4>
            <ul class="checklist-sm">
              <li><span class="check green">✓</span> Domínio de prompts</li>
              <li><span class="check green">✓</span> Criar novos agentes</li>
              <li><span class="check green">✓</span> Debugar e otimizar</li>
              <li><span class="check green">✓</span> Arquiteturas multi-agente</li>
              <li><span class="check green">✓</span> Mindset adequado para IA</li>
            </ul>
          </div>

          <div class="deliverable-column">
            <div class="column-icon">🤝</div>
            <h4>Comunidade</h4>
            <ul class="checklist-sm">
              <li><span class="check green">✓</span> Grupo exclusivo vitalício</li>
              <li><span class="check green">✓</span> Network com profissionais</li>
              <li><span class="check green">✓</span> Certificado de conclusão</li>
              <li><span class="check green">✓</span> Atualizações futuras</li>
            </ul>
          </div>
        </div>
      </section>

      <!-- SLIDE 13: INVESTIMENTO -->
      <section data-background-color="#08080C">
        <h2 class="slide-title">Investimento</h2>

        <div class="pricing-hero">
          <div class="price-box">
            <div class="price-main">R$ 4.990</div>
            <div class="price-sub">ou <span class="text-accent">10x de R$ 499</span> no cartão</div>
          </div>
        </div>

        <div class="included-grid">
          <div class="included-item"><span class="check-icon">✓</span> 4h presenciais (Floripa)</div>
          <div class="included-item"><span class="check-icon">✓</span> 12h online ao vivo (6x 2h)</div>
          <div class="included-item"><span class="check-icon">✓</span> 2-3h encontro final</div>
          <div class="included-item"><span class="check-icon">✓</span> Sessão com Claudia Guirunas</div>
          <div class="included-item"><span class="check-icon">✓</span> Materiais completos</div>
          <div class="included-item"><span class="check-icon">✓</span> Gravações das aulas</div>
          <div class="included-item"><span class="check-icon">✓</span> Templates e códigos</div>
          <div class="included-item"><span class="check-icon">✓</span> Grupo vitalício</div>
          <div class="included-item"><span class="check-icon">✓</span> Certificado</div>
          <div class="included-item"><span class="check-icon">✓</span> Suporte contínuo</div>
        </div>

        <div class="guarantee-box">
          <div class="guarantee-icon">🔒</div>
          <h4>Garantia de 7 Dias</h4>
          <p>Se após o primeiro encontro você não estiver satisfeito, devolvemos 100% do valor. Sem perguntas.</p>
        </div>
      </section>

      <!-- SLIDE 14: FAQ -->
      <section data-background-color="#0C0C12">
        <h2 class="slide-title">Perguntas Frequentes</h2>

        <div class="faq-grid">
          <div class="faq-item">
            <h4>❓ Preciso saber programar?</h4>
            <p>Não! Ensinamos tudo do zero no encontro presencial.</p>
          </div>

          <div class="faq-item">
            <h4>📍 E se não puder ir a Floripa?</h4>
            <p>O presencial é fundamental. Recomendamos aguardar turma futura.</p>
          </div>

          <div class="faq-item">
            <h4>⏰ Quanto tempo dura?</h4>
            <p>~19 horas em 8 encontros ao longo de 6-8 semanas.</p>
          </div>

          <div class="faq-item">
            <h4>🎯 Vou criar minha squad?</h4>
            <p>Sim! Autonomia completa para criar agentes do zero.</p>
          </div>

          <div class="faq-item">
            <h4>💼 Posso usar comercialmente?</h4>
            <p>100%! Tudo que criar é seu para usar como quiser.</p>
          </div>

          <div class="faq-item">
            <h4>🎓 Terei suporte depois?</h4>
            <p>Acesso vitalício ao grupo de mentorados.</p>
          </div>
        </div>
      </section>

      <!-- SLIDE 15: CTA FINAL -->
      <section class="slide-cta" data-background-gradient="linear-gradient(135deg, #FF4400 0%, #FF6B35 100%)">
        <div class="cta-content">
          <div class="badge-animated white">
            <span class="ping white"></span>
            <span class="label">MAIO 2026</span>
          </div>

          <h1 class="cta-title">Garanta Sua Vaga</h1>
          <p class="cta-subtitle">Apenas 8 vagas restantes</p>

          <div class="cta-benefits">
            <div class="benefit-item">✓ Tudo instalado e configurado</div>
            <div class="benefit-item">✓ Sua primeira squad funcionando</div>
            <div class="benefit-item">✓ O mindset certo</div>
            <div class="benefit-item">✓ Clareza total sobre o caminho</div>
          </div>

          <div class="cta-footer">
            <p class="cta-text">E nas próximas semanas: <strong>uma equipe completa de agentes autônomos trabalhando para você.</strong></p>
            <p class="cta-note">🔒 Pagamento seguro | ⏰ Turmas limitadas | ✅ Garantia 7 dias</p>
          </div>
        </div>
      </section>

    </div>
  </div>

  <script is:inline src="https://cdn.jsdelivr.net/npm/reveal.js@5.0.4/dist/reveal.js"></script>

  <style>
    /* Reset Reveal.js defaults and apply custom theme */
    .reveal {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      font-size: 18px;
      font-weight: normal;
      color: rgba(255, 255, 255, 0.9);
    }

    .reveal .slides {
      text-align: left;
    }

    .reveal section {
      height: 100%;
      padding: 3rem 4rem;
      box-sizing: border-box;
    }

    /* Typography */
    .title-xl {
      font-size: 4rem;
      font-weight: 800;
      line-height: 1.1;
      margin: 2rem 0 1rem;
      color: white;
    }

    .text-accent {
      color: #FF4400;
    }

    .subtitle {
      font-size: 1.5rem;
      color: rgba(255, 255, 255, 0.7);
      margin-bottom: 3rem;
    }

    .slide-title {
      font-size: 2.5rem;
      font-weight: 700;
      margin-bottom: 2rem;
      color: white;
    }

    .subtitle-sm {
      font-size: 1.3rem;
      font-weight: 600;
      margin-bottom: 1rem;
      color: rgba(255, 255, 255, 0.9);
    }

    .text-lg {
      font-size: 1.2rem;
      line-height: 1.6;
      margin-bottom: 1.5rem;
    }

    .text-md {
      font-size: 1rem;
      line-height: 1.5;
      color: rgba(255, 255, 255, 0.8);
    }

    .text-sm {
      font-size: 0.9rem;
      color: rgba(255, 255, 255, 0.6);
    }

    /* Badges */
    .badge-animated {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: rgba(8, 8, 12, 0.8);
      border: 1px solid rgba(255, 68, 0, 0.3);
      padding: 0.5rem 1rem;
      margin-bottom: 2rem;
    }

    .badge-animated.white {
      background: rgba(255, 255, 255, 0.2);
      border: 1px solid rgba(255, 255, 255, 0.3);
    }

    .ping {
      position: relative;
      display: flex;
      height: 8px;
      width: 8px;
    }

    .ping::before {
      content: '';
      position: absolute;
      height: 100%;
      width: 100%;
      background: #FF4400;
      border-radius: 50%;
      animation: ping 1.5s cubic-bezier(0, 0, 0.2, 1) infinite;
    }

    .ping::after {
      content: '';
      position: absolute;
      height: 100%;
      width: 100%;
      background: #FF4400;
      border-radius: 50%;
    }

    .ping.white::before,
    .ping.white::after {
      background: white;
    }

    @keyframes ping {
      75%, 100% {
        transform: scale(2);
        opacity: 0;
      }
    }

    .label {
      font-family: 'Geist Mono', monospace;
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-weight: 600;
      color: #FF4400;
    }

    .badge-animated.white .label {

    .price-main {
      font-size: 4rem;
      font-weight: 800;
      color: white;
    }

    .price-sub {
      font-size: 1.5rem;
      color: rgba(255, 255, 255, 0.7);
      margin-top: 0.5rem;
    }

    .included-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.8rem;
      margin-bottom: 2rem;
    }

    .included-item {

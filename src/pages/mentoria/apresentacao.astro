      font-family: 'Geist Mono', monospace;
      font-weight: 600;
      color: #FF4400;
      font-size: 0.9rem;
    }

    /* MCP Grid */
    .mcp-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      margin-top: 2rem;
    }

    .mcp-card {
      background: rgba(255, 255, 255, 0.03);

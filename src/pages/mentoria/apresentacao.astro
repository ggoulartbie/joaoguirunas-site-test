    }

    .anatomy-item p {
      font-size: 0.85rem;
      color: rgba(255, 255, 255, 0.6);
      line-height: 1.4;
    }

    /* Final Grid */
    .final-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      margin-top: 2rem;
    }

    .final-card {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 8px;
      padding: 1.5rem;
      text-align: center;
    }

    .final-icon {
      font-size: 2.5rem;
      margin-bottom: 0.8rem;
    }

    .final-card h4 {
      font-size: 1.1rem;
      margin: 0.5rem 0;
      color: white;
    }

    .final-card p {
      font-size: 0.85rem;
      color: rgba(255, 255, 255, 0.6);
      line-height: 1.4;
      margin: 0;
    }

    /* Personas Grid */
    .personas-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
      margin: 1.5rem 0;
    }

    .persona-card {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 8px;
      padding: 1rem;
      text-align: center;
    }

    .persona-icon {
      font-size: 2rem;
      margin-bottom: 0.5rem;
    }

    .persona-card h4 {
      font-size: 0.9rem;
      margin: 0;
      color: white;
    }

    .requirements-box {
      background: rgba(14, 165, 233, 0.1);
      border: 1px solid rgba(14, 165, 233, 0.3);
      padding: 1.5rem;
      border-radius: 8px;
      margin-top: 2rem;
    }

    .requirements-box h4 {
      font-size: 1rem;
      margin: 0 0 0.8rem 0;
      color: white;
    }

    .note {
      margin-top: 1rem;
      font-size: 0.9rem;
      color: rgba(255, 255, 255, 0.7);
    }

    /* Deliverables Grid */
    .deliverables-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }

    .deliverable-column {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 8px;
      padding: 1.5rem;
    }

    .column-icon {
      font-size: 2.5rem;
      margin-bottom: 0.8rem;
    }

    .deliverable-column h4 {
      font-size: 1.2rem;
      margin: 0 0 1rem 0;
      color: white;
    }

    /* Pricing */
    .pricing-hero {

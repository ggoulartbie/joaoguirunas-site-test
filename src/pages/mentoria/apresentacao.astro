    /* Skills Grid */
    .skills-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
      margin: 1.5rem 0;
    }

    .skill-card {
      background: rgba(255, 68, 0, 0.1);
      border: 1px solid rgba(255, 68, 0, 0.3);
      padding: 0.8rem 1.2rem;
      border-radius: 6px;

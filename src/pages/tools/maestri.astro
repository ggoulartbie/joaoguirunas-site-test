---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Maestri" description="Comunicação inter-agentes entre terminais. Conecte múltiplos Claude Code para colaboração em tempo real.">
  <section class="py-24">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="mb-8">
        <ol class="flex items-center gap-2 text-sm text-white/50">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li>/</li>
          <li class="text-[#FF4500]">Maestri</li>
        </ol>
      </nav>

      <!-- Header -->
      <div class="mb-12">
        <div class="inline-flex items-center gap-2 rounded-full bg-[#FF4500]/10 px-3 py-1 text-sm font-medium text-[#FF4500] mb-4">
          Tools
        </div>
        <h1 class="text-4xl font-bold text-white sm:text-5xl">
          Maestri
        </h1>
        <p class="mt-4 text-xl text-white/70">
          Comunicação inter-agentes entre terminais. Conecte múltiplos Claude Code para colaboração em tempo real.
        </p>
      </div>

      <!-- Content -->
      <div class="prose prose-invert prose-lg max-w-none">
        <div class="rounded-xl border border-white/[0.08] bg-[#121218] p-8 text-center">
          <div class="inline-flex items-center justify-center rounded-lg bg-[#FF4500]/10 p-4 mb-4">
            <svg class="h-8 w-8 text-[#FF4500]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155"/>
            </svg>
          </div>
          <h2 class="text-2xl font-semibold text-white mb-2">Em Breve</h2>
          <p class="text-white/60">
            Documentação completa e guia de instalação chegando em breve.
          </p>
          <a
            href="https://github.com/joaoguirunas"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-6 inline-flex items-center gap-2 rounded-lg bg-[#FF4500] px-5 py-2.5 text-sm font-semibold text-white hover:bg-[#FF5722] transition-colors"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            Ver no GitHub
          </a>
        </div>
      </div>

      <!-- Back Link -->
      <div class="mt-12">
        <a href="/" class="inline-flex items-center gap-2 text-[#FF4500] hover:underline">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          Voltar para todas as ferramentas
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

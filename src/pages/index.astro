---

<BaseLayout title="Open Source Skills">
  <!-- Hero Section -->
  <section id="hero" class="relative w-full max-h-[45vh] sm:max-h-[55vh] overflow-hidden">
    <!-- Background Image - Ultrawide Panoramic -->
    <img
      src="/images/hero-ultrawide.png"
      alt="Equipe GrowthSales AI trabalhando com agentes autônomos e inteligência artificial"
      class="w-full h-[45vh] sm:h-[55vh] object-cover"
      style="object-position: center 25%;"
    />

    <!-- Dark Overlay Gradient - Transparent top, dark bottom -->
    <div class="absolute inset-0 bg-gradient-to-b from-[#08080C]/10 via-[#08080C]/40 to-[#08080C]/95"></div>

    <!-- Content - Positioned at bottom -->
    <div class="absolute inset-0 flex flex-col justify-end px-4 sm:px-6 pb-12 sm:pb-16 md:pb-20">
      <div class="mx-auto max-w-6xl w-full">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2.5 bg-[#08080C] px-3 sm:px-4 py-1.5 mb-3 sm:mb-4">
          <span class="relative flex h-2 w-2" aria-hidden="true">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[#FF4400] opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-[#FF4400]"></span>
          </span>
          <span class="text-[#FF4400]" style="font-family: 'Geist Mono', monospace; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.14em; font-weight: 600;">100% Open Source</span>
        </div>

        <!-- Title -->
        <h1 class="text-xl sm:text-2xl md:text-3xl lg:text-4xl font-bold tracking-tight text-white">
          Open Source <span class="text-[#FF4400]">Skills</span>
        </h1>
        <p class="mt-2 text-sm sm:text-base md:text-lg text-white/80">
          by <span class="text-[#FF4400] font-medium">GrowthSales AI</span>
        </p>

        <!-- CTA Buttons -->
        <div class="mt-4 sm:mt-6 flex flex-col sm:flex-row items-stretch sm:items-center gap-3">
          <a
            href="#skills"
            class="btn-primary inline-flex items-center justify-center gap-2 bg-[#FF4400] px-5 py-3 text-sm sm:text-base text-white shadow-lg shadow-[#FF4400]/25 hover:bg-[#FF5C10] transition-all"
            aria-label="Explorar skills open source"
          >
            Explorar Skills
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
            </svg>
          </a>
          <a
            href="/mentoria"
            class="inline-flex items-center justify-center gap-2 border border-white/20 bg-white/5 px-5 py-3 text-white hover:bg-white/10 transition-all backdrop-blur-sm"
            style="font-family: 'Geist Mono', monospace; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.06em; font-weight: 500;"
            aria-label="Ir para página de mentoria"
          >
            Mentoria
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Skills Grid -->
  <section id="skills" class="py-16 sm:py-20 md:py-24 bg-[#08080C]">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <!-- Section Header -->
      <div class="text-center mb-12 sm:mb-16">
        <div class="inline-flex items-center gap-2 sm:gap-3 border border-[#FF4400]/30 bg-[#FF4400]/10 px-4 sm:px-5 py-2 mb-4 sm:mb-6">
          <img src="/images/claude-logo.png" alt="Logo Claude AI" class="h-4 sm:h-5 w-4 sm:w-5" />
          <span class="text-[#FF4400]" style="font-family: 'Geist Mono', monospace; font-size: 0.6rem; sm:font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.12em; font-weight: 600;">Skills para Claude Code</span>
        </div>
        <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold text-white px-4">
          Tudo o que você precisa para <span class="text-[#FF4400]">escalar com IA</span>
        </h2>
        <div class="mx-auto mt-4 sm:mt-6 w-24 accent-line"></div>
        <p class="mt-4 sm:mt-6 text-base sm:text-lg text-white/70 max-w-2xl mx-auto px-4">
          Skills, Squads, Apps e Integrações open source para multiplicar produtividade com agentes autônomos
        </p>
      </div>

      <!-- Category Filters -->
      <div class="flex flex-wrap justify-center gap-3 mb-12">
        <button
          data-filter="all"
          class="filter-btn active inline-flex items-center border px-4 py-2 transition-all bg-[#FF4400] text-white border-[#FF4400]"
          style="font-family: 'Geist Mono', monospace; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600;"
        >
          Todos
        </button>
        {categories.map((cat) => (
          <button
            data-filter={cat.id}
            class="filter-btn inline-flex items-center border px-4 py-2 transition-all bg-transparent text-white/70 border-white/10 hover:border-white/20 hover:text-white"
            style="font-family: 'Geist Mono', monospace; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600;"
          >
            {cat.label}
          </button>
        ))}
      </div>

      <!-- Grid -->

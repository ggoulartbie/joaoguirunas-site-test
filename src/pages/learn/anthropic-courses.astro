const longDescription = [
  'Curadoria completa dos 13 cursos gratuitos da Anthropic para aprender a construir com Claude. De prompt engineering básico até sistemas de agentes complexos.',
  'Os cursos cobrem fundamentos de LLMs, técnicas avançadas de prompting, integração de ferramentas, RAG, processamento multimodal, e boas práticas de segurança.',
  'Todo o conteúdo é oficial da Anthropic e atualizado regularmente. Ideal para desenvolvedores e profissionais que querem dominar o ecossistema Claude.',
];
---

<SkillPage
  title="Cursos Anthropic"
  description="Curadoria dos 13 cursos gratuitos da Anthropic. Aprenda a construir com Claude."
  category="Aprendizado"
  categoryColor="aprendizado"
  longDescription={longDescription}
  features={features}
  primaryLink="https://github.com/anthropics/courses"
  primaryLabel="Ver Cursos no GitHub"
  author="Anthropic"
  authorUrl="https://github.com/anthropics"
  bgImage="/images/bg-learn.png"
/>

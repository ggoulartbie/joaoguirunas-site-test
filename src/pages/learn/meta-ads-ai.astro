---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Meta Ads com IA" description="Automação de campanhas Meta com agentes. Otimize criativos, copy e targeting automaticamente.">
  <section class="py-24">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="mb-8">
        <ol class="flex items-center gap-2 text-sm text-white/50">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li>/</li>
          <li class="text-[#FF4500]">Meta Ads com IA</li>
        </ol>
      </nav>

      <!-- Header -->
      <div class="mb-12">
        <div class="inline-flex items-center gap-2 rounded-full bg-[#FF4500]/10 px-3 py-1 text-sm font-medium text-[#FF4500] mb-4">
          Learn
        </div>
        <h1 class="text-4xl font-bold text-white sm:text-5xl">
          Meta Ads com IA
        </h1>
        <p class="mt-4 text-xl text-white/70">
          Automação de campanhas Meta com agentes. Otimize criativos, copy e targeting automaticamente.
        </p>
      </div>

      <!-- Content -->
      <div class="prose prose-invert prose-lg max-w-none">
        <div class="rounded-xl border border-white/[0.08] bg-[#121218] p-8 text-center">
          <div class="inline-flex items-center justify-center rounded-lg bg-[#FF4500]/10 p-4 mb-4">
            <svg class="h-8 w-8 text-[#FF4500]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.34 15.84c-.688-.06-1.386-.09-2.09-.09H7.5a4.5 4.5 0 110-9h.75c.704 0 1.402-.03 2.09-.09m0 9.18c.253.962.584 1.892.985 2.783.247.55.06 1.21-.463 1.511l-.657.38c-.551.318-1.26.117-1.527-.461a20.845 20.845 0 01-1.44-4.282m3.102.069a18.03 18.03 0 01-.59-4.59c0-1.586.205-3.124.59-4.59m0 9.18a23.848 23.848 0 018.835 2.535M10.34 6.66a23.847 23.847 0 008.835-2.535m0 0A23.74 23.74 0 0018.795 3m.38 1.125a23.91 23.91 0 011.014 5.395m-1.014 8.855c-.118.38-.245.754-.38 1.125m.38-1.125a23.91 23.91 0 001.014-5.395m0-3.46c.495.413.811 1.035.811 1.73 0 .695-.316 1.317-.811 1.73m0-3.46a24.347 24.347 0 010 3.46"/>
            </svg>
          </div>
          <h2 class="text-2xl font-semibold text-white mb-2">Em Breve</h2>
          <p class="text-white/60">
            Documentação completa e guia de instalação chegando em breve.
          </p>
          <a
            href="https://github.com/joaoguirunas"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-6 inline-flex items-center gap-2 rounded-lg bg-[#FF4500] px-5 py-2.5 text-sm font-semibold text-white hover:bg-[#FF5722] transition-colors"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            Ver no GitHub
          </a>
        </div>
      </div>

      <!-- Back Link -->
      <div class="mt-12">
        <a href="/" class="inline-flex items-center gap-2 text-[#FF4500] hover:underline">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          Voltar para todas as ferramentas
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

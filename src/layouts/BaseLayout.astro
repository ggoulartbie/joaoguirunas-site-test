---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Open Source Tools by GrowthSales AI — Ferramentas para multiplicar produtividade com agentes autônomos.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="pt-BR" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{title} | GrowthSales Open Source</title>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="GrowthSales Open Source" />
    <meta property="og:url" content="https://opensource.growthsales.ai" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
  </head>
  <body class="min-h-screen bg-[#08080C] text-white antialiased">
    <!-- Header -->
    <header class="fixed top-0 left-0 right-0 z-50 border-b border-white/[0.08] bg-[#08080C]/80 backdrop-blur-xl">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex h-16 items-center justify-between">
          <!-- Logo -->
          <a href="/" class="flex items-center gap-3 font-semibold text-white hover:opacity-90 transition-opacity">
            <img src="/logo.png" alt="GrowthSales" class="h-9 w-9" />
            <span class="text-lg tracking-tight">GrowthSales</span>
          </a>

          <!-- Navigation Desktop -->
          <nav class="hidden md:flex items-center gap-8">
            <a href="/" class="text-sm font-medium text-white/70 hover:text-white transition-colors">Home</a>
            <a href="/#products" class="text-sm font-medium text-white/70 hover:text-white transition-colors">Tools</a>
            <a href="/learn/anthropic-courses" class="text-sm font-medium text-white/70 hover:text-white transition-colors">Learn</a>
          </nav>

          <!-- CTA Mentoria -->
          <div class="flex items-center gap-4">
            <a
              href="https://growthsales.ai/mentoria"
              target="_blank"
              rel="noopener noreferrer"
              class="hidden sm:inline-flex items-center gap-2 rounded-lg bg-[#FF4500] px-5 py-2.5 text-sm font-semibold text-white shadow-lg shadow-[#FF4500]/20 hover:bg-[#FF5722] hover:shadow-[#FF4500]/30 transition-all"
            >
              Mentoria
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
              </svg>
            </a>

            <!-- Mobile Menu Button -->
            <button
              id="mobile-menu-btn"
              class="md:hidden inline-flex items-center justify-center rounded-lg p-2 text-white/70 hover:text-white hover:bg-white/5 transition-colors"
              aria-label="Menu"
            >
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
              </svg>
            </button>
          </div>
        </div>

        <!-- Mobile Menu -->
        <div id="mobile-menu" class="hidden md:hidden border-t border-white/[0.08] py-4">
          <nav class="flex flex-col gap-2">
            <a href="/" class="px-4 py-2 text-sm font-medium text-white/70 hover:text-white hover:bg-white/5 rounded-lg transition-colors">Home</a>
            <a href="/#products" class="px-4 py-2 text-sm font-medium text-white/70 hover:text-white hover:bg-white/5 rounded-lg transition-colors">Tools</a>
            <a href="/learn/anthropic-courses" class="px-4 py-2 text-sm font-medium text-white/70 hover:text-white hover:bg-white/5 rounded-lg transition-colors">Learn</a>
            <a
              href="https://growthsales.ai/mentoria"
              target="_blank"
              rel="noopener noreferrer"
              class="mx-4 mt-2 inline-flex items-center justify-center gap-2 rounded-lg bg-[#FF4500] px-5 py-2.5 text-sm font-semibold text-white hover:bg-[#FF5722] transition-colors"
            >
              Mentoria
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
              </svg>
            </a>
          </nav>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="pt-16">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-white/[0.08] bg-[#0D0D12]">
      <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
        <!-- Footer Grid -->
        <div class="grid gap-12 md:grid-cols-4">
          <!-- Brand -->
          <div class="md:col-span-2">
            <a href="/" class="flex items-center gap-3">
              <img src="/logo.png" alt="GrowthSales" class="h-10 w-10" />
              <span class="text-xl font-semibold text-white">GrowthSales</span>
            </a>
            <p class="mt-4 max-w-sm text-sm text-white/50 leading-relaxed">
              Multiplicando produtividade com agentes autônomos. Ferramentas open source para quem trabalha com IA.
            </p>
          </div>

          <!-- Links -->
          <div>
            <h4 class="text-sm font-semibold text-white mb-4">Ferramentas</h4>
            <ul class="space-y-3">
              <li><a href="/monitor/aiox-monitor" class="text-sm text-white/50 hover:text-white transition-colors">AIOX Monitor</a></li>
              <li><a href="/framework/aiox-framework" class="text-sm text-white/50 hover:text-white transition-colors">AIOX Framework</a></li>
              <li><a href="/tools/maestri" class="text-sm text-white/50 hover:text-white transition-colors">Maestri</a></li>
              <li><a href="/skills/aiox-skills" class="text-sm text-white/50 hover:text-white transition-colors">AIOX Skills</a></li>
            </ul>
          </div>

          <!-- Learn -->
          <div>
            <h4 class="text-sm font-semibold text-white mb-4">Aprender</h4>
            <ul class="space-y-3">
              <li><a href="/setup/claude-code" class="text-sm text-white/50 hover:text-white transition-colors">Setup Claude Code</a></li>
              <li><a href="/learn/anthropic-courses" class="text-sm text-white/50 hover:text-white transition-colors">Cursos Anthropic</a></li>
              <li><a href="https://growthsales.ai/mentoria" target="_blank" rel="noopener noreferrer" class="text-sm text-[#FF4500] hover:text-[#FF5722] transition-colors">Mentoria</a></li>
            </ul>
          </div>
        </div>

        <!-- Bottom -->
        <div class="mt-12 pt-8 border-t border-white/[0.08] flex flex-col sm:flex-row items-center justify-between gap-4">
          <p class="text-sm text-white/35">
            &copy; 2025 GrowthSales AI. Todos os direitos reservados.
          </p>

          <!-- Social Links -->
          <div class="flex items-center gap-4">
            <a
              href="https://github.com/SynkraAI"
              target="_blank"
              rel="noopener noreferrer"
              class="text-white/40 hover:text-white transition-colors"
              aria-label="GitHub"
            >
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
            </a>
            <a
              href="https://linkedin.com/company/growthsales-ai"
              target="_blank"
              rel="noopener noreferrer"
              class="text-white/40 hover:text-white transition-colors"
              aria-label="LinkedIn"
            >
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
            <a
              href="https://twitter.com/growthsales_ai"
              target="_blank"
              rel="noopener noreferrer"
              class="text-white/40 hover:text-white transition-colors"
              aria-label="Twitter"
            >
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </footer>

    <!-- Mobile Menu Script -->
    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>

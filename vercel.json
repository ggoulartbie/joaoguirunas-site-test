{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "opensource.growthsales.ai" }],
      "destination": "https://joaoguirunas.com/$1",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/daily",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/hourly",
      "schedule": "0 * * * *"
    }
  ]
}

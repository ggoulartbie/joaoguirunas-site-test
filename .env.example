# ============================================
# Environment Variables — Plataforma de Cursos
# ============================================
# Copie para .env.local e preencha com os valores reais.
# NUNCA comite .env.local — está no .gitignore.
# ============================================

# --------------------------------------------
# Supabase
# Painel: Settings → API
# --------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://mksmmpfyqowuzjcchhkl.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# CRÍTICO: ignora RLS. Apenas server-side (Route Handlers, Server Actions, webhooks).
# NUNCA importar em Client Components.
SUPABASE_SERVICE_ROLE_KEY=

# --------------------------------------------
# Stripe
# Painel: Developers → API Keys
# --------------------------------------------
STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# --------------------------------------------
# Vimeo
# Painel: Settings → Apps
# --------------------------------------------
VIMEO_ACCESS_TOKEN=
VIMEO_DOMAIN_WHITELIST=

# --------------------------------------------
# Resend (email)
# Painel: API Keys
# --------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --------------------------------------------
# App
# --------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --------------------------------------------
# Sentry (Fase 8)
# Painel: Settings → Client Keys (DSN)
# --------------------------------------------
# DSN público — usado no cliente (browser) e no servidor
NEXT_PUBLIC_SENTRY_DSN=
# DSN para server-side e edge (pode ser igual ao NEXT_PUBLIC)
SENTRY_DSN=
# Auth token para upload de source maps em CI/CD
# Painel: Settings → Auth Tokens
SENTRY_AUTH_TOKEN=

# --------------------------------------------
# LLM / Tools (AIOX — não relacionado à plataforma)
# --------------------------------------------
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
EXA_API_KEY=
CONTEXT7_API_KEY=
FREEPIK_API_KEY=

# --------------------------------------------
# DevOps / CI (não relacionado à plataforma)
# --------------------------------------------
GITHUB_TOKEN=
VERCEL_TOKEN=
RAILWAY_TOKEN=

# --------------------------------------------
# Integrações externas (não relacionado à plataforma)
# --------------------------------------------
CLICKUP_API_KEY=
N8N_API_KEY=
N8N_WEBHOOK_URL=

# --------------------------------------------
# AIOX Core
# --------------------------------------------
NODE_ENV=development
AIOX_VERSION=2.2.0

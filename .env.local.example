# ============================================
# .env.local.example — Plataforma de Cursos
# ============================================
# Copie para .env.local e preencha com os valores reais.
# NUNCA comite .env.local — está no .gitignore.
# ============================================

# --------------------------------------------
# Supabase (obrigatório)
# Painel: Settings → API
# --------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# CRÍTICO: ignora RLS. Apenas server-side (Route Handlers, Server Actions, webhooks).
SUPABASE_SERVICE_ROLE_KEY=

# --------------------------------------------
# Stripe (obrigatório)
# Painel: Developers → API Keys
# Use sk_live_ / whsec_ em produção, sk_test_ em dev
# --------------------------------------------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Registrar endpoint no Stripe Dashboard:
#   https://seudominio.com/api/webhooks/stripe
#   Eventos: checkout.session.completed, invoice.paid,
#            invoice.payment_failed, charge.refunded

# --------------------------------------------
# Resend (obrigatório)
# Painel: resend.com → API Keys
# Verificar domínio de envio antes do deploy
# --------------------------------------------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@seudominio.com

# --------------------------------------------
# Vimeo (obrigatório se houver vídeos)
# Painel: vimeo.com → Settings → Apps
# VIMEO_DOMAIN_WHITELIST: domínio que pode embedar os vídeos
# --------------------------------------------
VIMEO_ACCESS_TOKEN=
VIMEO_DOMAIN_WHITELIST=seudominio.com

# --------------------------------------------
# App (obrigatório)
# URL pública do site — usada em links de email e redirects OAuth
# --------------------------------------------
NEXT_PUBLIC_APP_URL=https://seudominio.com

# --------------------------------------------
# Cron (obrigatório)
# String aleatória para autenticar o endpoint /api/cron/daily
# Gerar: openssl rand -hex 32
# Configurar no Vercel: Settings → Cron Jobs → Secret
# --------------------------------------------
CRON_SECRET=

# --------------------------------------------
# Sentry (opcional — monitoramento de erros)
# Painel: sentry.io → Settings → Client Keys (DSN)
# SENTRY_AUTH_TOKEN: Settings → Auth Tokens (para upload de source maps em CI)
# --------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
